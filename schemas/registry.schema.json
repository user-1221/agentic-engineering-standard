{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aes.dev/schemas/registry/v1",
  "title": "AES Registry Definition",
  "description": "Validates .agent/registry/*.yaml component registries",
  "type": "object",
  "required": ["aes_registry", "id", "categories"],
  "properties": {
    "aes_registry": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "description": {
      "type": "string"
    },
    "entry_schema": {
      "type": "object",
      "properties": {
        "required": {
          "type": "array",
          "items": { "$ref": "#/$defs/schema_field" }
        },
        "optional": {
          "type": "array",
          "items": { "$ref": "#/$defs/schema_field" }
        },
        "dynamic": {
          "type": "array",
          "items": { "$ref": "#/$defs/schema_field" }
        }
      }
    },
    "interface": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "functions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "signature": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "categories": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "schema_field": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" }
      }
    }
  }
}
