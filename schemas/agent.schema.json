{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aes.dev/schemas/agent/v1",
  "title": "AES Agent Manifest",
  "description": "Validates .agent/agent.yaml — the central manifest for an AES project",
  "type": "object",
  "required": ["aes", "name", "version", "description"],
  "properties": {
    "aes": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "AES spec version (e.g., '1.0')"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$",
      "description": "Project name in kebab-case"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+",
      "description": "Semantic version"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "One-line project description"
    },
    "domain": {
      "type": "string",
      "description": "Project domain (ml, web, devops, data-pipeline, etc.)"
    },
    "license": {
      "type": "string"
    },
    "repository": {
      "type": "string",
      "format": "uri"
    },
    "author": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      }
    },
    "runtime": {
      "type": "object",
      "properties": {
        "language": { "type": "string" },
        "version": { "type": "string" },
        "entry_point": { "type": "string" },
        "setup": { "type": "string" }
      },
      "required": ["language"]
    },
    "agent": {
      "type": "object",
      "required": ["instructions"],
      "properties": {
        "instructions": {
          "type": "string",
          "description": "Path to instructions.md relative to .agent/"
        },
        "permissions": {
          "type": "string",
          "description": "Path to permissions.yaml relative to .agent/"
        },
        "orchestrator": {
          "type": "string",
          "description": "Path to ORCHESTRATOR.md relative to .agent/"
        }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/skill_ref"
      }
    },
    "registries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/registry_ref"
      }
    },
    "workflows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflow_ref"
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/command_ref"
      }
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "skills": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "environment": {
      "type": "object",
      "properties": {
        "required": {
          "type": "array",
          "items": { "$ref": "#/$defs/env_var" }
        },
        "optional": {
          "type": "array",
          "items": { "$ref": "#/$defs/env_var_optional" }
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "max_cpu_percent": { "type": "integer", "minimum": 1, "maximum": 100 },
        "max_memory_percent": { "type": "integer", "minimum": 1, "maximum": 100 },
        "max_concurrent_jobs": { "type": "integer", "minimum": 1 },
        "max_disk_usage_mb": { "type": "integer", "minimum": 1 },
        "coexistence_note": { "type": "string" }
      }
    },
    "models": {
      "type": "array",
      "description": "AI models this agent uses",
      "items": { "$ref": "#/$defs/model_ref" }
    },
    "provenance": {
      "type": "object",
      "description": "Where this agent came from",
      "properties": {
        "created_by": { "type": "string" },
        "created_at": { "type": "string", "format": "date" },
        "source": { "type": "string" },
        "signed_by": { "type": "string" }
      }
    },
    "interop": {
      "type": "object",
      "description": "Cross-protocol references for agent discovery",
      "properties": {
        "a2a_card": { "type": "string", "format": "uri" },
        "mcp_servers": {
          "type": "array",
          "items": { "$ref": "#/$defs/mcp_server_ref" }
        }
      }
    },
    "identity": {
      "type": "object",
      "description": "Agent identity and persona for persistent/daemon agents",
      "properties": {
        "persona": { "type": "string", "description": "Agent persona, behavioral rules, tone" },
        "name": { "type": "string", "description": "Agent display name" },
        "emoji": { "type": "string", "description": "Agent emoji identifier" },
        "user_profile": { "type": "string", "description": "User profile and preferred form of address" }
      }
    },
    "model": {
      "type": "object",
      "description": "Primary LLM provider configuration",
      "properties": {
        "provider": { "type": "string", "description": "Provider ID (anthropic, openai, google, ollama, etc.)" },
        "model": { "type": "string", "description": "Model identifier" },
        "api_key_env": { "type": "string", "description": "Environment variable name for API key (never a raw key)" },
        "base_url": { "type": ["string", "null"], "description": "Custom endpoint URL" },
        "fallback": {
          "type": "array",
          "description": "Failover model chain",
          "items": { "$ref": "#/$defs/model_fallback" }
        }
      }
    },
    "agents": {
      "type": "array",
      "description": "Multi-agent declarations",
      "items": { "$ref": "#/$defs/agent_decl" }
    },
    "sandbox": {
      "type": "object",
      "description": "Sandbox/container configuration for agent execution",
      "properties": {
        "enabled": { "type": "boolean" },
        "runtime": {
          "type": "string",
          "enum": ["docker", "openshell"],
          "description": "Sandbox runtime (docker built-in or openshell for NemoClaw)"
        },
        "workspace_root": { "type": "string", "description": "Workspace root inside container" }
      }
    },
    "heartbeat": {
      "type": "object",
      "description": "Autonomous heartbeat scheduler configuration",
      "properties": {
        "interval_minutes": { "type": "integer", "minimum": 1, "description": "Minutes between heartbeat runs" },
        "checklist": { "type": "string", "description": "Markdown checklist of tasks to perform each heartbeat" }
      }
    },
    "channels": {
      "type": "object",
      "description": "Messaging platform integrations",
      "additionalProperties": { "$ref": "#/$defs/channel_config" }
    },
    "mcp_servers": {
      "type": "object",
      "description": "Top-level MCP server declarations (keyed by server name)",
      "additionalProperties": { "$ref": "#/$defs/mcp_server_decl" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "skill_ref": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
        "manifest": { "type": "string" },
        "runbook": { "type": "string" }
      }
    },
    "registry_ref": {
      "type": "object",
      "required": ["id", "path"],
      "properties": {
        "id": { "type": "string" },
        "path": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "workflow_ref": {
      "type": "object",
      "required": ["id", "path"],
      "properties": {
        "id": { "type": "string" },
        "path": { "type": "string" }
      }
    },
    "command_ref": {
      "type": "object",
      "required": ["id", "path"],
      "properties": {
        "id": { "type": "string" },
        "path": { "type": "string" },
        "trigger": { "type": "string", "pattern": "^/" },
        "description": { "type": "string" }
      }
    },
    "env_var": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "env_var_optional": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "default": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "model_ref": {
      "type": "object",
      "required": ["name", "provider"],
      "properties": {
        "name": { "type": "string" },
        "provider": { "type": "string" },
        "version": { "type": "string" },
        "purpose": {
          "type": "string",
          "enum": ["primary", "fallback", "embedding", "evaluation"]
        }
      }
    },
    "mcp_server_ref": {
      "type": "object",
      "required": ["name", "transport"],
      "properties": {
        "name": { "type": "string" },
        "transport": {
          "type": "string",
          "enum": ["stdio", "sse", "streamable-http"]
        },
        "command": { "type": "string" },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "model_fallback": {
      "type": "object",
      "required": ["provider", "model"],
      "properties": {
        "provider": { "type": "string" },
        "model": { "type": "string" }
      }
    },
    "agent_decl": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
        "workspace": { "type": "string" },
        "model_override": {
          "type": "object",
          "properties": {
            "provider": { "type": "string" },
            "model": { "type": "string" }
          }
        },
        "mcp_servers": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "channel_config": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "bot_token_env": { "type": "string", "description": "Environment variable name for the bot token" }
      },
      "additionalProperties": true
    },
    "mcp_server_decl": {
      "type": "object",
      "properties": {
        "command": { "type": "string" },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "disabled": { "type": "boolean" }
      }
    }
  }
}
