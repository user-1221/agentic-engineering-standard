{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aes.dev/schemas/permissions/v1",
  "title": "AES Permissions Model",
  "description": "Validates .agent/permissions.yaml",
  "type": "object",
  "required": ["aes_permissions"],
  "properties": {
    "aes_permissions": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "allow": {
      "$ref": "#/$defs/permission_set"
    },
    "deny": {
      "$ref": "#/$defs/permission_set"
    },
    "confirm": {
      "type": "object",
      "properties": {
        "shell": {
          "type": "array",
          "items": { "type": "string" }
        },
        "files": {
          "type": "object",
          "properties": {
            "read": { "$ref": "#/$defs/pattern_or_patterns" },
            "write": { "$ref": "#/$defs/pattern_or_patterns" },
            "create": { "$ref": "#/$defs/pattern_or_patterns" },
            "delete": { "$ref": "#/$defs/pattern_or_patterns" }
          }
        },
        "actions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "resource_limits": {
      "type": "object",
      "properties": {
        "max_cpu_percent": { "type": "integer", "minimum": 1, "maximum": 100 },
        "max_memory_percent": { "type": "integer", "minimum": 1, "maximum": 100 },
        "check_before": {
          "type": "array",
          "items": { "type": "string" }
        },
        "on_exceeded": {
          "type": "string",
          "enum": ["warn_and_skip", "wait_and_retry", "abort"]
        }
      }
    },
    "network": {
      "type": "object",
      "description": "Network access controls",
      "properties": {
        "allow": { "type": "array", "items": { "type": "string" } },
        "deny": { "type": "array", "items": { "type": "string" } },
        "confirm": { "type": "array", "items": { "type": "string" } }
      }
    },
    "process": {
      "type": "object",
      "description": "Process execution restrictions",
      "properties": {
        "allow": { "type": "array", "items": { "type": "string" } },
        "deny": { "type": "array", "items": { "type": "string" } }
      }
    },
    "inference": {
      "type": "object",
      "description": "Model routing and rate constraints",
      "properties": {
        "routing": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["task", "models"],
            "properties": {
              "task": { "type": "string" },
              "models": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "max_tokens_per_request": { "type": "integer", "minimum": 1 },
        "max_requests_per_minute": { "type": "integer", "minimum": 1 }
      }
    },
    "data": {
      "type": "object",
      "description": "Data handling policies",
      "properties": {
        "classification": {
          "type": "string",
          "enum": ["public", "internal", "confidential", "restricted"]
        },
        "retention_days": { "type": "integer", "minimum": 1 },
        "pii_handling": {
          "type": "string",
          "enum": ["redact", "mask", "prohibit", "allow"]
        }
      }
    },
    "overrides": {
      "type": "object",
      "additionalProperties": true
    },
    "filesystem": {
      "type": "object",
      "description": "Filesystem access policy (maps to OpenShell filesystem_policy)",
      "properties": {
        "enforcement": {
          "type": "string",
          "enum": ["best_effort", "enforce"]
        },
        "read_only": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Paths agent can read but not write"
        },
        "read_write": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Paths agent can read and write"
        }
      }
    },
    "tools": {
      "type": "object",
      "description": "Tool execution approval policies",
      "properties": {
        "approval_mode": {
          "type": "string",
          "description": "Tool approval mode (ask, a2h, record, ignore)"
        },
        "assurance_levels": {
          "type": "object",
          "description": "Per-command assurance levels (HIGH, MEDIUM, LOW)",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "permission_set": {
      "type": "object",
      "properties": {
        "shell": {
          "oneOf": [
            {
              "type": "array",
              "items": { "type": "string" }
            },
            {
              "type": "object",
              "properties": {
                "read": { "type": "array", "items": { "type": "string" } },
                "execute": { "type": "array", "items": { "type": "string" } },
                "remote": { "type": "array", "items": { "type": "string" } }
              }
            }
          ]
        },
        "files": {
          "type": "object",
          "properties": {
            "read": { "$ref": "#/$defs/pattern_or_patterns" },
            "write": { "$ref": "#/$defs/pattern_or_patterns" },
            "create": { "$ref": "#/$defs/pattern_or_patterns" },
            "delete": { "$ref": "#/$defs/pattern_or_patterns" }
          }
        }
      }
    },
    "pattern_or_patterns": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    }
  }
}
